# Copy to .env and fill in values. Never commit .env.

# Set to 1 or true to skip requiring Telegram and at least one product URL (tooling / local experiments)
DRY_RUN=false

# --- Telegram (required for production monitor) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Monitored products ---
# Comma-separated list of full Pokémon Center product page URLs (no spaces).
# Example: https://www.pokemoncenter.com/product/...,https://www.pokemoncenter.com/product/...
PRODUCT_URLS=

# --- Runtime ---
# SQLite database file path (parent directory is created if missing)
DATABASE_PATH=./data/restock.db

# Poll interval between full monitor cycles (seconds)
POLL_INTERVAL_SECONDS=300

# After an in-stock alert, suppress repeat in-stock alerts for the same product (seconds). 0 = off.
ALERT_DEBOUNCE_SECONDS=0

# Retries for Playwright navigation and Telegram (T18): attempts, base delay (ms), exponential backoff
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
RETRY_EXPONENTIAL=true

# Discovery: scrape product links from listing/category pages each poll tick (optional)
DISCOVERY_ENABLED=false
# Comma-separated listing URLs on pokemoncenter.com (required when discovery is on)
# Example: https://www.pokemoncenter.com/en-us/category/new-arrivals
DISCOVERY_SEED_URLS=

# Playwright: set to 1 or true for headed browser (debug)
PLAYWRIGHT_HEADED=false

# Logging: debug | info | warn | error
LOG_LEVEL=info
